<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- Tamanho do seu RadioButton -->
    <size
        android:width="24dp"
        android:height="24dp" />

    <!-- Borda do RadioButton -->
    <stroke
        android:width="2dp"
        android:color="@color/Amarelo" /> <!-- Cor padrão da borda -->

    <!-- Preenchimento interno (opcional) -->
    <solid android:color="@android:color/transparent" />
</shape>